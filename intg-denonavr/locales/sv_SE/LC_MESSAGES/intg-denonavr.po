msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Plural-Forms: nplurals=2; plural=n != 1;\n"
"Language: sv_SE\n"

msgid "Control your Denon or Marantz AVRs with Remote Two/3."
msgstr "Styr dina AV-receivrar från Denon eller Marantz med Remote Two/3."

msgid "Integration setup"
msgstr "Integrationskonfigurering"

msgid "Setup process"
msgstr "Konfigureringsprocess"

msgid "The integration discovers Denon and Marantz Receivers on the network."
msgstr "Integrationen upptäcker Denon och Marantz Audio Video Receivers (AVR) på nätverk."

msgid "Please note that this integration can take 2-4s before it's ready to send commands after the remote starts or wakes up."
msgstr "Observera att det kan ta 2-4 sekunder innan denna integration är redo att skicka kommandon efter att fjärrkontrollen har startats eller väckts."

msgid "Please see our support article for requirements, features and restrictions."
msgstr "Vänligen se vår [supportartikel](https://support.unfoldedcircle.com/hc/en-us/articles/19480446994844) för tekniska krav, stödda funktioner och begränsningar."

msgid "Setup mode"
msgstr "Konfigureringsprocess"

msgid "Leave blank to use auto-discovery and click _Next_."
msgstr "Lämna tomt för att hitta automatiskt och klicka på _Nästa_."

msgid "The device must be on the same network as the remote."
msgstr "Enheten måste vara ansluten till samma nätverk som fjärrkontrollen."

msgid "Manual IP address or hostname"
msgstr "Manuell IP-adress eller värdnamn"

msgid "Please note:"
msgstr "Vänligen notera:"

msgid "Using telnet provides realtime updates for many values but certain receivers allow a single connection only!"
msgstr "Telnet möjliggör realtidsuppdateringar för många värden. Notera att vissa modeller endast tillåter en anslutning via detta protokoll samtidigt. Andra appar och system kan sluta att fungera om du använder Telnet."

msgid "Add a new device"
msgstr "Lägg till en ny enhet"

msgid "Configure selected device"
msgstr "Konfigurera vald enhet"

msgid "Delete selected device"
msgstr "Ta bort vald enhet"

msgid "Reset configuration and reconfigure"
msgstr "Återställ konfiguration och konfigurera igen"

msgid "Configuration mode"
msgstr "Konfigurationsläge"

msgid "Configured devices"
msgstr "Konfigurerade enheter"

msgid "Action"
msgstr "Åtgärd"

msgid "Configure your AVR"
msgstr "Konfigurera din AVR"

msgid "Please choose your Denon or Marantz AVR"
msgstr "Vänligen välj din Denon eller Marantz AVR"

msgid "Choose your Denon or Marantz AVR"
msgstr "Välj din Denon- eller Marantz-AV-receiver"

msgid "Show all sources"
msgstr "Visa alla källor"

msgid "Select manufacturer"
msgstr "Välj tillverkare"

msgid "Connection mode"
msgstr "Konfigurationssätt"

msgid "Use Telnet connection"
msgstr "Använd en Telnet-anslutning"

msgid "Use HTTP connection"
msgstr "Använd HTTP-anslutning"

msgid "Volume step"
msgstr "Volymsteg"

msgid "Connection and request timeout"
msgstr "Anslutnings- och begäranstimeout (ms)"

msgid "Device supports Dirac"
msgstr "Enheten stöder Dirac"

msgid "Yes"
msgstr "Ja"

msgid "No"
msgstr "Nej"
