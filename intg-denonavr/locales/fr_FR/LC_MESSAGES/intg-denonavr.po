msgid "Control your Denon or Marantz AVRs with Remote Two/3."
msgstr "Contrôlez vos amplis-tuners AV Denon ou Marantz à l'aide d'Remote Two/3."

msgid "Integration setup"
msgstr "Configuration de l'intégration"

msgid "Setup process"
msgstr "Installation"

msgid "The integration discovers Denon and Marantz Receivers on the network."
msgstr "Cette intégration détecte les récepteurs audio-vidéo (AVR) Denon et Marantz présents sur le réseau."

msgid "Please note that this integration can take 2-4s before it's ready to send commands after the remote starts or wakes up."
msgstr "Veuillez noter que cette intégration peut prendre entre 2 et 4 secondes avant d'être prête à envoyer des commandes après le démarrage ou la sortie de veille de la télécommande."

msgid "Please see our support article for requirements, features and restrictions."
msgstr "Consulte [l’article de support](https://support.unfoldedcircle.com/hc/en-us/articles/19480446994844) pour connaître les exigences, les fonctionnalités prises en charge et les restrictions."

msgid "Setup mode"
msgstr "Installation"

msgid "Leave blank to use auto-discovery and click _Next_."
msgstr "Laissez le champ vide pour utiliser la découverte automatique et cliquez sur _Suivant_."

msgid "The device must be on the same network as the remote."
msgstr "L'appareil doit se trouver sur le même réseau que la télécommande."

msgid "Manual IP address or hostname"
msgstr "Adresse IP ou nom d'hôte saisi manuellement"

msgid "Please note:"
msgstr "Veuillez noter:"

msgid "Using telnet provides realtime updates for many values but certain receivers allow a single connection only!"
msgstr "L'utilisation de Telnet fournit des mises à jour en temps réel pour de nombreuses valeurs, mais certains amplificateurs ne permettent qu'une seule connexion ! Avec ce paramètre, d'autres applications ou systèmes ne peuvent plus fonctionner."

msgid "Add a new device"
msgstr "Ajouter un nouvel appareil"

msgid "Configure selected device"
msgstr "Configurer l'appareil sélectionné"

msgid "Delete selected device"
msgstr "Supprimer l'appareil sélectionné"

msgid "Reset configuration and reconfigure"
msgstr "Réinitialiser la configuration et reconfigurer"

msgid "Configuration mode"
msgstr "Mode de configuration"

msgid "Configured devices"
msgstr "Appareils configurés"

msgid "Action"
msgstr "Action"

msgid "Configure your AVR"
msgstr "Configurez votre AVR"

msgid "Please choose your Denon or Marantz AVR"
msgstr "Veuillez choisir votre Denon ou Marantz AVR"

msgid "Choose your Denon or Marantz AVR"
msgstr "Choisissez votre amplificateur AV Denon ou Marantz"

msgid "Show all sources"
msgstr "Afficher tous les sources"

msgid "Select manufacturer"
msgstr "Sélectionner fabricant"

msgid "Connection mode"
msgstr "Mode de connexion"

msgid "Use Telnet connection"
msgstr "Utilisez une connexion Telnet"

msgid "Use HTTP connection"
msgstr "Utilise une connexion HTTP"

msgid "Volume step"
msgstr "Incrément de volume"

msgid "Connection and request timeout"
msgstr "Délai d'expiration de la connexion et de la requête (ms)"

msgid "Device supports Dirac"
msgstr "L'appareil supporte Dirac"

msgid "Yes"
msgstr "Oui"

msgid "No"
msgstr "Non"
