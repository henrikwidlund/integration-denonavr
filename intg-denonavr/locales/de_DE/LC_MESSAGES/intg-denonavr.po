msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Plural-Forms: nplurals=2; plural=n != 1;\n"
"Language: de_DE\n"

msgid "Control your Denon or Marantz AVRs with Remote Two/3."
msgstr "Steuere deine Denon- oder Marantz-AV-Receiver mit Remote Two/3."

msgid "Integration setup"
msgstr "Integrationssetup"

msgid "Setup process"
msgstr "Setup Modus"

msgid "The integration discovers Denon and Marantz Receivers on the network."
msgstr "Die Integration erkennt Denon- und Marantz-Audio-Video-Receiver (AVR) im Netzwerk."

msgid "Please note that this integration can take 2-4s before it's ready to send commands after the remote starts or wakes up."
msgstr "Bitte beachte, dass diese Integration 2-4 Sekunden brauchen kann, bis sie bereit ist, Befehle zu senden, nachdem die Fernbedienung gestartet wurde oder aus dem Ruhemodus erwacht ist."

msgid "Please see our support article for requirements, features and restrictions."
msgstr "Bitte beachte unseren [Support-Artikel](https://support.unfoldedcircle.com/hc/en-us/articles/19480446994844) zu Anforderungen, unterstützten Funktionen und Einschränkungen."

msgid "Setup mode"
msgstr "Setup Modus"

msgid "Leave blank to use auto-discovery and click _Next_."
msgstr "Leer lassen, um automatische Erkennung zu verwenden und auf _Weiter_ klicken."

msgid "The device must be on the same network as the remote."
msgstr "Das Gerät muss sich im selben Netzwerk wie die Fernbedienung befinden."

msgid "Manual IP address or hostname"
msgstr "Manuelle IP-Adresse oder Hostname"

msgid "Please note:"
msgstr "Bitte beachten:"

msgid "Using telnet provides realtime updates for many values but certain receivers allow a single connection only!"
msgstr "Die Verwendung von Telnet bietet Echtzeit-Updates für viele Werte, aber bestimmte Verstärker erlauben nur eine einzige Verbindung! Mit dieser Einstellung können andere Apps oder Systeme nicht mehr funktionieren."

msgid "Add a new device"
msgstr "Ein neues Gerät hinzufügen"

msgid "Configure selected device"
msgstr "Selektiertes Gerät konfigurieren"

msgid "Delete selected device"
msgstr "Selektiertes Gerät löschen"

msgid "Reset configuration and reconfigure"
msgstr "Konfiguration zurücksetzen und neu konfigurieren"

msgid "Configuration mode"
msgstr "Konfigurationsmodus"

msgid "Configured devices"
msgstr "Konfigurierte Geräte"

msgid "Action"
msgstr "Aktion"

msgid "Configure your AVR"
msgstr "Konfiguriere deinen AVR"

msgid "Please choose your Denon or Marantz AVR"
msgstr "Bitte wähle deinen Denon oder Marantz AVR"

msgid "Choose your Denon or Marantz AVR"
msgstr "Wähle deinen Denon- oder Marantz-AV-Receiver aus"

msgid "Show all sources"
msgstr "Alle Quellen anzeigen"

msgid "Select manufacturer"
msgstr "Hersteller auswählen"

msgid "Connection mode"
msgstr "Verbindungstyp"

msgid "Use Telnet connection"
msgstr "Telnet-Verbindung nutzen"

msgid "Use HTTP connection"
msgstr "HTTP-Verbindung verwenden"

msgid "Volume step"
msgstr "Lautstärkeschritt"

msgid "Connection and request timeout"
msgstr "Verbindungs- und Anfrage-Timeout (ms)"

msgid "Device supports Dirac"
msgstr "Gerät unterstützt Dirac"

msgid "Yes"
msgstr "Ja"

msgid "No"
msgstr "Nein"
